# === 实验 8-6 环境变量示例：复制为 .env 后填入你的 Key ===

# 选择服务商：openai（默认）| moonshot | ark
PROVIDER=openai

# OpenAI（默认使用，默认模型 gpt-5.6-luna）
OPENAI_API_KEY=your_openai_api_key_here

# 统一兜底：若上面 provider 的 Key 缺失，但设置了 OPENROUTER_API_KEY，
# 则自动改走 OpenRouter，并把模型名映射到 openai/gpt-5.6-luna 等。
# OPENROUTER_API_KEY=sk-or-...

# 备选：Kimi / 火山方舟（把 PROVIDER 改成 moonshot 或 ark 时使用）
# MOONSHOT_API_KEY=your_moonshot_api_key_here
# ARK_API_KEY=your_ark_api_key_here

# 被测 Agent 生成工具用的模型（默认 gpt-5.6-luna）
AGENT_MODEL=gpt-5.6-luna
# LLM-as-a-Judge 打分用的模型（默认 gpt-5.6-luna）
JUDGE_MODEL=gpt-5.6-luna
TEMPERATURE=0.2
